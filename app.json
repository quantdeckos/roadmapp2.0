{
  "expo": {
    "name": "RoadMapp",
    "slug": "roadmapp-ui",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#111111"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.roadmapp.mobile"
    },
    "android": {
      "package": "com.roadmapp.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#111111"
      }
    },
    "plugins": [
      "expo-notifications",
      "expo-asset",
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "replace-with-your-eas-project-id"
      }
    }
  }
}
